mlns=\"http://www.w3.org/2000/svg\"\n          version=\"1.1\"\n          xmlnsXlink=\"http://www.w3.org/1999/xlink\"\n          xmlns:svgjs=\"http://svgjs.dev/svgjs\"\n          viewBox=\"0 0 1500 233\"\n          width=\"1500\"\n          height=\"233\"\n        >\n          <defs>\n            <filter\n              id=\"nnnoise-filter\"\n              x=\"-20%\"\n              y=\"-20%\"\n              width=\"140%\"\n              height=\"140%\"\n              filterUnits=\"objectBoundingBox\"\n              primitiveUnits=\"userSpaceOnUse\"\n              colorInterpolationFilters=\"linearRGB\"\n            >\n              <feTurbulence\n                type=\"fractalNoise\"\n                baseFrequency=\"0.173\"\n                numOctaves=\"4\"\n                seed=\"15\"\n                stitchTiles=\"stitch\"\n                x=\"0%\"\n                y=\"0%\"\n                width=\"100%\"\n                height=\"100%\"\n                result=\"turbulence\"\n              ></feTurbulence>\n              <feSpecularLighting\n                surfaceScale=\"10\"\n                specularConstant=\"1.7\"\n                specularExponent=\"20\"\n                lightingColor=\"#8f2a2a\"\n                x=\"0%\"\n                y=\"0%\"\n                width=\"100%\"\n                height=\"100%\"\n                in=\"turbulence\"\n                result=\"specularLighting\"\n              >\n                <feDistantLight azimuth=\"3\" elevation=\"65\"></feDistantLight>\n              </feSpecularLighting>\n              <feColorMatrix\n                type=\"saturate\"\n                values=\"0\"\n                x=\"0%\"\n                y=\"0%\"\n                width=\"100%\"\n                height=\"100%\"\n                in=\"specularLighting\"\n                result=\"colormatrix\"\n              ></feColorMatrix>\n            </filter>\n          </defs>\n          <rect width=\"1500\" height=\"233\" fill=\"transparent\"></rect>\n          <rect\n            width=\"1500\"\n            height=\"233\"\n            fill=\"#8f2a2a\"\n            filter=\"url(#nnnoise-filter)\"\n          ></rect>\n        </svg>\n      </div>\n      <h2 className=\"scrolling-title\">\n        {' '}\n        <a href=\"/build-your-own-desktop\">Gaming PC Builder</a>\n      </h2>\n      <div className=\"scrolling-wrapper\">\n        <div ref={scrollRef} className=\"scrolling-content\">\n          <a href=\"/build-your-own-desktop\" className=\"scrolling-item\">\n            <img\n              loading=\"lazy\"\n              width={75}\n              height={75}\n              src=\"https://cdn.shopify.com/s/files/1/0552/0883/7292/files/56789-600x600_copy.webp?v=1744193136&format=webp&width=75\"\n              alt=\"Gaming Desktop Setup\"\n            />\n            <img\n              loading=\"lazy\"\n              width={75}\n              height={75}\n              src=\"https://cdn.shopify.com/s/files/1/0552/0883/7292/files/1691936722_MX360-01.webp?v=1742897747&format=webp&width=75\"\n              alt=\"Gaming Desktop Case\"\n            />\n            <img\n              loading=\"lazy\"\n              width={75}\n              height={75}\n              src=\"https://cdn.shopify.com/s/files/1/0552/0883/7292/files/h525.png?v=1742897747&format=webp&width=75\"\n              alt=\"Gaming GPU\"\n            />\n            <img\n              loading=\"lazy\"\n              width={75}\n              height={75}\n              src=\"https://cdn.shopify.com/s/files/1/0552/0883/7292/files/msi-mpg_z490_gaming_carbon_wifi-3d2_rgb.png?v=1742897747&format=webp&width=75\"\n              alt=\"Gaming Motherboard\"\n            />\n            <img\n              loading=\"lazy\"\n              width={75}\n              height={75}\n              src=\"https://cdn.shopify.com/s/files/1/0552/0883/7292/files/ae-odyssey-neo-g9-g95nc-ls57cg952nmxue-541731703.avif?v=1742894737&format=webp&width=75\"\n              alt=\"Ga