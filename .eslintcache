"Remove the console.dir().",{"propertyName":"3130"},{"range":"3519","text":"2267"},{"propertyName":"3130"},{"range":"3520","text":"2267"},{"propertyName":"3130"},{"range":"3521","text":"2267"},{"propertyName":"3130"},{"range":"3522","text":"2267"},{"propertyName":"3130"},{"range":"3523","text":"2267"},{"propertyName":"3302"},{"range":"3524","text":"2267"},{"propertyName":"3302"},{"range":"3525","text":"2267"},{"propertyName":"3302"},{"range":"3526","text":"2267"},{"propertyName":"3302"},{"range":"3527","text":"2267"},{"propertyName":"3302"},{"range":"3528","text":"2267"},{"propertyName":"3302"},{"range":"3529","text":"2267"},{"propertyName":"3130"},{"range":"3530","text":"2267"},{"propertyName":"3302"},{"range":"3531","text":"2267"},{"propertyName":"3130"},{"range":"3532","text":"2267"},{"propertyName":"3130"},{"range":"3533","text":"2267"},{"propertyName":"3060"},{"range":"3534","text":"2267"},{"propertyName":"3060"},{"range":"3535","text":"2267"},{"propertyName":"3060"},{"range":"3536","text":"2267"},{"propertyName":"3130"},{"range":"3537","text":"2267"},{"propertyName":"3130"},{"range":"3538","text":"2267"},{"propertyName":"3302"},{"range":"3539","text":"2267"},{"propertyName":"3302"},{"range":"3540","text":"2267"},{"propertyName":"3130"},{"range":"3541","text":"2267"},{"propertyName":"3302"},{"range":"3542","text":"2267"},{"propertyName":"3302"},{"range":"3543","text":"2267"},{"propertyName":"3302"},{"range":"3544","text":"2267"},{"propertyName":"3302"},{"range":"3545","text":"2267"},{"propertyName":"3302"},{"range":"3546","text":"2267"},{"propertyName":"3302"},{"range":"3547","text":"2267"},{"propertyName":"3130"},{"range":"3548","text":"2267"},{"propertyName":"3302"},{"range":"3549","text":"2267"},"warn",[582,642],[127,4088],"import {Image} from '@shopify/hydrogen';\n\n\n\n/**\n * BannerSlideshow\n * -----------------------------------------\n * • Detects the visitor’s device once.\n *   ─ Server side: looks for `isMobile` in loader data\n *     (generated with `const isMobile = /mobile/i.test(userAgent)`).\n *   ─ Client side: re-checks `navigator.userAgent` after hydration.\n * • Renders one <img>/<video> variant per slide:\n *   ─ Mobile visitors → mobile assets only\n *   ─ Desktop visitors → desktop assets only\n * • Keeps all existing autoplay, swipe, arrows, dots, progress bar.\n */\n\nexport function BannerSlideshow({banners, interval = 10000}) {\n  /* -------------------------------------------------------------\n   * 1)  DEVICE DETECTION\n   * ----------------------------------------------------------- */\n  const loaderData = useLoaderData() || {};\n  const ssrIsMobile = !!loaderData.isMobile; // may be undefined if loader omitted\n  const [isMobile, setIsMobile] = useState(ssrIsMobile);\n\n  /* After hydration, double-check on the client */\n  useEffect(() => {\n    if (typeof navigator !== 'undefined') {\n      setIsMobile(/mobile/i.test(navigator.userAgent));\n    }\n  }, []);\n\n  /* Helper to detect if a URL is a video file */\n  const isVideoUrl = (url) =>\n    typeof url === 'string' && /\\.(mp4|webm|ogg)(?:$|\\?)/i.test(url);\n\n  /* Filter banners so we only iterate the ones we’ll really show */\n  const deviceBanners = useMemo(\n    () =>\n      isMobile\n        ? banners.filter((b) => b.mobileImageUrl || b.mobileVideoUrl)\n        : banners.filter((b) => b.desktopImageUrl || b.desktopVideoUrl),\n    [banners, isMobile],\n  );\n\n  /* -------------------------------------------------------------\n   * 2)  SLIDESHOW STATE\n   * ----------------------------------------------------------- */\n  const [current, setCurrent] = useState(0);\n  const timerRef = useRef(null);\n  const touchStartX = useRef(0);\n\n  const next = useCallback(\n    () => setCurrent((i) => (i + 1) % deviceBanners.length),\n    [deviceBanners.length],\n  );\n\n  const prev = useCallback(\n    () => setCurrent((i) => (i ? i - 1 : deviceBanners.length - 1)),\n    [deviceBanners.length],\n  );\n\n  /* Autoplay */\n  useEffect(() => {\n    clearInterval(timerRef.current);\n    timerRef.current = setInterval(next, interval);\n    return () => clearInterval(timerRef.current);\n  }, [interval, next, current]);\n\n  /* Swipe handlers */\n  const onTouchStart = (e) => (touchStartX.current = e.touches[0].clientX);\n  const onTouchEnd = (e) => {\n    const diff = e.changedTouches[0].clientX - touchStartX.current;\n    if (diff > 100) prev();\n    if (diff < -100) next();\n  };\n\n  /* No banners for this device? – gracefully abort */\n  if (!deviceBanners.length) return null;\n\n  const slide = deviceBanners[current];\n  const isFirstSlide = current === 0;\n\n  /* -------------------------------------------------------------\n   * 3)  RENDER\n   * ----------------------------------------------------------- */\n  return (\n    <>\n      <figure\n        className=\"banner-slideshow\"\n        onTouchStart={onTouchStart}\n        onTouchEnd={onTouchEnd}\n      >\n        <a href={slide.link} className=\"banner-link\">\n          {isMobile\n            ? /* Mobile asset (image or video) */\n              (() => {\n                const videoSrc =\n                  slide.mobileVideoUrl ||\n                  (isVideoUrl(slide.mobileImageUrl)\n                    ? slide.mobileImageUrl\n                    : null);\n                if (videoSrc) {\n                  return (\n                    <video\n                      src={videoSrc}\n                      className=\"banner-image\"\n                      autoPlay\n                      loop\n                      muted\n                      playsInline\n                      preload=\"auto\"\n                      width={640}\n                      height={300}\n                      aria-label={slide.alt || `Banner ${current + 1}`}\n                    />\n                  );\n                }\n                return (\n                  <Image",[127,5716],"import {Image} from '@shopify/hydrogen';\n\n\n\n/**\n * BannerSlideshow\n * -----------------------------------------\n * • Detects the visitor’s device once.\n *   ─ Server side: looks for `isMobile` in loader data\n *     (generated with `const isMobile = /mobile/i.test(userAgent)`).\n *   ─ Client side: re-checks `navigator.userAgent` after hydration.\n * • Renders one <img>/<video> variant per slide:\n *   ─ Mobile visitors → mobile assets only\n *   ─ Desktop visitors → desktop assets only\n * • Keeps all existing autoplay, swipe, arrows, dots, progress bar.\n */\n\nexport function BannerSlideshow({banners, interval = 10000}) {\n  /* -------------------------------------------------------------\n   * 1)  DEVICE DETECTION\n   * ----------------------------------------------------------- */\n  const loaderData = useLoaderData() || {};\n  const ssrIsMobile = !!loaderData.isMobile; // may be undefined if loader omitted\n  const [isMobile, setIsMobile] = useState(ssrIsMobile);\n\n  /* After hydration, double-check on the client */\n  useEffect(() => {\n    if (typeof navigator !== 'undefined') {\n      setIsMobile(/mobile/i.test(navigator.userAgent));\n    }\n  }, []);\n\n  /* Helper to detect if a URL is a video file */\n  const isVideoUrl = (url) =>\n    typeof url === 'string' && /\\.(mp4|webm|ogg)(?:$|\\?)/i.test(url);\n\n  /* Filter banners so we only iterate the ones we’ll really show */\n  const deviceBanners = useMemo(\n    () =>\n      isMobile\n        ? banners.filter((b) => b.mobileImageUrl || b.mobileVideoUrl)\n        : banners.filter((b) => b.desktopImageUrl || b.desktopVideoUrl),\n    [banners, isMobile],\n  );\n\n  /* -------------------------------------------------------------\n   * 2)  SLIDESHOW STATE\n   * ----------------------------------------------------------- */\n  const [current, setCurrent] = useState(0);\n  const timerRef = useRef(null);\n  const touchStartX = useRef(0);\n\n  const next = useCallback(\n    () => setCurrent((i) => (i + 1) % deviceBanners.length),\n    [deviceBanners.length],\n  );\n\n  const prev = useCallback(\n    () => setCurrent((i) => (i ? i - 1 : deviceBanners.length - 1)),\n    [deviceBanners.length],\n  );\n\n  /* Autoplay */\n  useEffect(() => {\n    clearInterval(timerRef.current);\n    timerRef.current = setInterval(next, interval);\n    return () => clearInterval(timerRef.current);\n  }, [interval, next, current]);\n\n  /* Swipe handlers */\n  const onTouchStart = (e) => (touchStartX.current = e.touches[0].clientX);\n  const onTouchEnd = (e) => {\n    const diff = e.changedTouches[0].clientX - touchStartX.current;\n    if (diff > 100) prev();\n    if (diff < -100) next();\n  };\n\n  /* No banners for this device? – gracefully abort */\n  if (!deviceBanners.length) return null;\n\n  const slide = deviceBanners[current];\n  const isFirstSlide = current === 0;\n\n  /* -------------------------------------------------------------\n   * 3)  RENDER\n   * ----------------------------------------------------------- */\n  return (\n    <>\n      <figure\n        className=\"banner-slideshow\"\n        onTouchStart={onTouchStart}\n        onTouchEnd={onTouchEnd}\n      >\n        <a href={slide.link} className=\"banner-link\">\n          {isMobile\n            ? /* Mobile asset (image or video) */\n              (() => {\n                const videoSrc =\n                  slide.mobileVideoUrl ||\n                  (isVideoUrl(slide.mobileImageUrl)\n                    ? slide.mobileImageUrl\n                    : null);\n                if (videoSrc) {\n                  return (\n                    <video\n                      src={videoSrc}\n                      className=\"banner-image\"\n                      autoPlay\n                      loop\n                      muted\n                      playsInline\n                      preload=\"auto\"\n                      width={640}\n                      height={300}\n                      aria-label={slide.alt || `Banner ${current + 1}`}\n                    />\n                  );\n                }\n                return (\n                  <img\n                    srcSet={`\n                    ${slide.mobileImageUrl}&format=webp&width=320 320w,\n                    ${slide.mobileImageUrl}&format=webp&width=480 480w,\n                    ${slide.mobileImageUrl}&format=webp&width=640 640w,\n                  `}\n                    sizes=\"100vw\"\n                    src={`${slide.mobileImageUrl}&format=webp&width=640`}\n                    alt={slide.alt || `Banner ${current + 1}`}\n                    className=\"banner-image\"\n                    loading={isFirstSlide ? 'eager' : 'lazy'}\n                    decoding=\"async\"\n                    fetchpriority={isFirstSlide ? 'high' : 'auto'}\n                    width={640}\n                    height={300}\n                  />\n                );\n              })()\n            : /* Desktop asset (image or video) */\n              (() => {\n                const videoSrc =\n                  slide.desktopVideoUrl ||\n                  (isVideoUrl(slide.desktopImageUrl)\n                    ? slide.desktopImageUrl\n                    : null);\n                if (videoSrc) {\n                  return (\n                    <video\n                      src={videoSrc}\n                      className=\"banner-image\"\n                      autoPlay\n                      loop\n                      muted\n                      playsInline\n                      preload=\"auto\"\n                      width={1500}\n                      height={300}\n                      aria-label={slide.alt || `Banner ${current + 1}`}\n                    />\n                  );\n                }\n                return (\n                  <Image",[0,95],"import {Image} from '@shopify/hydrogen';\n\n<div className=\"multiple-collection-section\">\n  <div className=\"collection-section-1\">\n    <Image",[0,524],"import {Image} from '@shopify/hydrogen';\n\n<div className=\"multiple-collection-section\">\n  <div classNam